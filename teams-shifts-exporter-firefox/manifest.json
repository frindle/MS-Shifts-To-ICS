{
  "manifest_version": 2,
  "name": "Teams Shifts to ICS",
  "version": "1.25.3",
  "description": "Scrape Microsoft Teams Shifts and export to ICS calendar file",
  "browser_specific_settings": {
    "gecko": {
      "id": "teams-shifts-ics@local",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": []
      }
    }
  },
  "permissions": [
    "storage",
    "alarms",
    "downloads",
    "tabs",
    "windows",
    "webNavigation",
    "notifications",
    "https://teams.cloud.microsoft/*",
    "https://flw.teams.cloud.microsoft/*",
    "https://outlook.office.com/*",
    "https://outlook.office365.com/*",
    "https://graph.microsoft.com/*",
    "https://*.icloud.com/*",
    "https://raw.githubusercontent.com/*"
  ],
  "background": {
    "scripts": ["background.js"],
    "persistent": true
  },
  "content_scripts": [
    {
      "matches": ["https://teams.cloud.microsoft/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://flw.teams.cloud.microsoft/*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    },
    {
      "matches": [
        "https://outlook.office.com/*",
        "https://outlook.office365.com/*"
      ],
      "js": ["outlook_content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "browser_action": {
    "default_popup": "popup.html",
    "default_title": "Teams Shifts to ICS",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png"
    }
  }
}
